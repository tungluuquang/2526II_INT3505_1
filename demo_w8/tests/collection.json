		{
			"name": "get all users",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response có success = true\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.success).to.eql(true);",
							"});",
							"",
							"pm.test(\"Data là array\", function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.data).to.be.an(\"array\");",
							"});",
							"",
							"pm.test('Mỗi user có đủ fields: id, name, email', function () {",
							"    pm.response.json().data.forEach(user => {",
							"        pm.expect(user).to.have.property('id');",
							"        pm.expect(user).to.have.property('name');",
							"        pm.expect(user).to.have.property('email');",
							"    });",
							"});",
							" ",
							"pm.test('Content-Type là application/json', function () {",
							"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
							"});",
							" ",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "{{baseUrl}}/",
