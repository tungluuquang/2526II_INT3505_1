							"",
							"pm.test(\"ID trả về đúng với userId\", function () {",
							"    const json = pm.response.json();",
							"    const expectedId = parseInt(pm.environment.get(\"userId\"));",
							"    ",
							"    pm.expect(json.data.id).to.eql(expectedId);",
							"});",
							"",
							"pm.test('User có đủ 5 fields: id, name, email, age, role', function () {",
							"    pm.expect(pm.response.json().data).to.have.all.keys('id', 'name', 'email', 'age', 'role');",
							"});",
